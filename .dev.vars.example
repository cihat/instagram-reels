# Copy to .dev.vars for OpenNext / Wrangler preview. For `next dev`, use the same keys in `.env.local`.
NEXTJS_ENV=development

# POST /api/fetch-metadata — strongly recommended in production
# FETCH_TRIGGER_SECRET=long-random-string

# Cookie line copied from the browser for Instagram web requests + /api/image-proxy (thumbnails) (sessionid=…; csrftoken=…; …)
# INSTAGRAM_COOKIES=

# Production (Workers): do not commit cookies to the repo — run once, then paste the value:
#   npx wrangler secret put INSTAGRAM_COOKIES
# Otherwise `wrangler deploy` may clear the INSTAGRAM_COOKIES variable from the Dashboard.
